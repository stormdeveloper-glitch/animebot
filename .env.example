# ── Asosiy Bot ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_main_bot_token_here
BOT_USERNAME=your_main_bot_username
SUPER_ADMIN_ID=123456789
ADMIN_IDS=123456789,987654321
MAIN_CHANNEL_ID=-1001234567890
MAIN_CHANNEL_USERNAME=@anime_channel_uz
# AI sozlamalari:
# Asosiy: Groq API (bepul, tez). Zaxira: OpenAI.
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_API_KEY=
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
WEB_PUBLIC_ORIGIN=
WEB_SESSION_TTL_HOURS=24
WEB_RATE_LIMIT_PER_MIN=180
WEB_API_RATE_LIMIT_PER_MIN=90
WEB_MEDIA_RATE_LIMIT_PER_MIN=120
WEB_MAX_CONCURRENT_REQUESTS=80
WEB_REQUEST_TIMEOUT_SECONDS=25
WEB_ADMIN_TOKEN=change_this_admin_panel_token
# Poster file_id olish uchun maxfiy chat. Kanal emas, o'zingizning Telegram ID'ingiz yoki yopiq admin guruh ID bo'lsin.
WEB_ADMIN_MEDIA_CHAT_ID=123456789
ADMIN_LOGIN=admin_secret_code
ADMIN_PASSWORD=admin_password_here
BOT_USER_RATE_LIMIT_PER_MIN=80

# ── Anime edits: Railway Bucket (S3-compatible) ─────────────────────────────
# Railway Bucket sahifasidagi endpoint, access key va secret key qiymatlarini kiriting.
# Bucket public bo'lishi yoki RAILWAY_BUCKET_PUBLIC_URL orqali o'qiladigan CDN/public URL berilishi kerak.
RAILWAY_BUCKET_ENDPOINT=
RAILWAY_BUCKET_REGION=auto
RAILWAY_BUCKET_NAME=
RAILWAY_BUCKET_ACCESS_KEY_ID=
RAILWAY_BUCKET_SECRET_ACCESS_KEY=
RAILWAY_BUCKET_PUBLIC_URL=

# ── Instagram Graph API (Business/Creator akkaunti) ─────────────────────────
# Token faqat serverdagi Railway Variables'da saqlansin, admin HTML ga yozmang.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_API_VERSION=v24.0

# ── Support Bot ───────────────────────────────────────────────────────────────
SUPPORT_BOT_TOKEN=your_support_bot_token_here
SUPPORT_BOT_USERNAME=your_support_bot_username
# Admin guruhi ID (support xabarlari shu guruhga keladi, -100 bilan boshlanadi)
SUPPORT_GROUP_ID=-1009876543210

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
